ENV=dev
PROJECT_NAME=agentic_web_starter
PROJECT_VERSION=0.1.0
PROJECT_DESCRIPTION="An agentic retrieval-augmented generation application."
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000
BASE_PATH=/agentic_web_starter
OPENAI_API_KEY="dummy-key"
GEMINI_API_KEY=""

# Working directory for uploads, logs, and vector data (default: current directory).
WORKING_DIR=

# Qdrant collection base name (default: agentic_web_starter).
COLLECTION_NAME=

# Hugging Face cache home (default: WORKING_DIR/hf).
HF_HOME=

JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Set to true to enable RAG and the upload endpoint. When false, /upload returns a configuration alert.
# If using upload, also configure QDRANT_HOST, QDRANT_PORT, QDRANT_PROTOCOL below.
USE_QDRANT=true

# Admin bootstrap (optional; created only if no users exist).
ADMIN_USERNAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_PROTOCOL=http

# Set to true to store chat history in Redis. When false, chat history is kept in memory.
USE_REDIS=true

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PROTOCOL=redis

# Set to true to enable SQL-backed auth and IAM routes (/auth, /users, /roles).
USE_SQL=true

# RabbitMQ (optional; master switch for message queue usage)
# When true: API uses queue for async processing (ingestion, etc.). Run the ingestion worker
# separately: python -m app.workers.ingestion_worker (or use the "worker" service in docker compose).
USE_RABBITMQ=false
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_VHOST=/

# If set, overrides HOST/PORT/USERNAME/PASSWORD/VHOST (example: amqp://guest:guest@rabbitmq:5672/)
RABBITMQ_AMQP_URL=

# Queue name consumed by the ingestion worker (app.workers.ingestion_worker).
RABBITMQ_INGEST_QUEUE=agentic_web_starter.ingestion