ENV=dev
PROJECT_NAME=agentic_rag
PROJECT_VERSION=0.1.0
PROJECT_DESCRIPTION="An agentic retrieval-augmented generation application."
ALLOWED_ORIGINS=*
BASE_PATH=/agentic_rag
OPENAI_API_KEY="dummy-key"
GEMINI_API_KEY=""

# Working directory for uploads, logs, and vector data (default: current directory).
WORKING_DIR=

# Qdrant collection base name (default: agentic_rag_template).
COLLECTION_NAME=

# Hugging Face cache home (default: WORKING_DIR/hf).
HF_HOME=

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_PROTOCOL=http 

REDIS_HOST=
REDIS_PORT=
REDIS_PROTOCOL=redis 