ENV=dev
PROJECT_NAME=agentic_rag
PROJECT_VERSION=0.1.0
PROJECT_DESCRIPTION="An agentic retrieval-augmented generation application."
ALLOWED_ORIGINS=*
BASE_PATH=/agentic_rag
OPENAI_API_KEY="dummy-key"

# Optional: Hugging Face token for faster model downloads (BAAI/bge-m3) and higher rate limits.
# HF_TOKEN=hf_...

QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_PROTOCOL=http 

REDIS_HOST=
REDIS_PORT=
REDIS_PROTOCOL=http 